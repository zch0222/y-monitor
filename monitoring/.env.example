# ============================================================
# Copy this file to .env and fill in your actual values,
# or run setup.sh which will prompt you interactively.
# .env is NOT committed to git (contains passwords).
# ============================================================

# Timezone for all containers
TZ=Asia/Shanghai

# Grafana admin credentials
# NOTE: GF_ADMIN_PASSWORD only takes effect on first init.
# If grafana/data already exists, use grafana-cli to reset the password.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=ChangeMe_123456

# Public domain for Grafana (used in GF_SERVER_ROOT_URL)
DOMAIN=monitor.example.com

# Prometheus TSDB retention
PROMETHEUS_RETENTION=30d

# Tailscale IPv4 of this monitoring host
MONITOR_TS_IP=100.x.x.x

# Loki mode:
# - embedded: run Loki on this monitoring host with docker compose --profile loki
# - external: use a Loki instance on another Tailscale host
LOKI_MODE=external

# Loki query endpoint for Grafana. Use Tailscale IP or MagicDNS.
LOKI_URL=http://100.x.x.x:3100

# Loki retention when LOKI_MODE=embedded
LOKI_RETENTION=336h
