# ============================================================
# Copy this file to .env and fill in your actual values.
# .env is NOT committed to git (contains passwords).
# ============================================================

# Timezone for all containers
TZ=Asia/Shanghai

# Grafana admin credentials
# NOTE: GF_ADMIN_PASSWORD only takes effect on first init.
# If grafana/data already exists, use grafana-cli to reset the password.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=ChangeMe_123456

# Public domain for Grafana (used in GF_SERVER_ROOT_URL and Nginx config)
DOMAIN=monitor.example.com

# SSL certificate directory (Let's Encrypt default path)
# fullchain.pem and privkey.pem must exist under this path.
CERT_DIR=/etc/letsencrypt/live/monitor.example.com

# Prometheus TSDB retention
PROMETHEUS_RETENTION=30d
