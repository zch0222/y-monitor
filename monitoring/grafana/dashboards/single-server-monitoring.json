    {
      "id": 38,
      "type": "table",
      "title": "探测目标列表",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 88 },
      "targets": [
        {
          "expr": "probe_success{job=~\"blackbox_http|blackbox_icmp|blackbox_tcp\", probe_node=\"$node\", direction=~\"$direction\"}",
          "instant": true,
          "format": "table",
          "refId": "Success"
        },
        {
          "expr": "probe_duration_seconds{job=~\"blackbox_http|blackbox_icmp|blackbox_tcp\", probe_node=\"$node\", direction=~\"$direction\"}",
          "instant": true,
          "format": "table",
          "refId": "Duration"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "__name__": true,
              "instance": true,
              "network": true,
              "blackbox_address": true
            },
            "indexByName": {
              "probe_type": 0,
              "direction": 1,
              "target": 2,
              "Value #Success": 3,
              "Value #Duration": 4
            },
            "renameByName": {
              "probe_type": "类型",
              "direction": "方向",
              "target": "目标",
              "Value #Success": "状态",
              "Value #Duration": "耗时"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "状态" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "失败", "color": "red", "index": 0 } } },
                  { "type": "value", "options": { "1": { "text": "成功", "color": "green", "index": 1 } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "耗时" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 1 },
                    { "color": "red", "value": 3 }
                  ]
                }
              },
              { "id": "max", "value": 5 }
            ]
          }
        ]
      }
    },
