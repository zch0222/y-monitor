      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 98 },
      "panels": []
    },
    {
      "id": 40,
      "type": "table",
      "title": "HTTPS 证书剩余有效期",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "只展示当前服务器作为探测节点时采集到的 HTTPS 证书有效期。",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 99 },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox_http\", probe_node=\"$node\", direction=~\"$direction\"} - time()) / 86400 and probe_ssl_earliest_cert_expiry{job=\"blackbox_http\", probe_node=\"$node\", direction=~\"$direction\"} > 0",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "network": true,
              "probe_node": true,
              "probe_region": true,
              "probe_type": true,
              "blackbox_address": true
            },
            "indexByName": {
              "direction": 0,
              "target": 1,
              "Value": 2
            },
            "renameByName": {
              "direction": "方向",
              "target": "目标",
              "Value": "剩余天数"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "剩余天数" },
            "properties": [
              { "id": "unit", "value": "d" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": 7 },
                    { "color": "green", "value": 30 }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
