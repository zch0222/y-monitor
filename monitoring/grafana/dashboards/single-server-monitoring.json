    {
      "id": 33,
      "type": "stat",
      "title": "当前平均探测耗时",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 53 },
      "targets": [
        {
          "expr": "avg(probe_duration_seconds{job=~\"blackbox_http|blackbox_icmp|blackbox_tcp\", probe_node=\"$node\", direction=~\"$direction\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "horizontal",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 34,
      "type": "table",
      "title": "探测耗时摘要（按类型 / 方向）",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 57 },
      "targets": [
        {
          "expr": "avg by(probe_type, direction) (probe_duration_seconds{job=~\"blackbox_http|blackbox_icmp|blackbox_tcp\", probe_node=\"$node\", direction=~\"$direction\"})",
          "instant": true,
          "format": "table",
          "refId": "Avg"
        },
        {
          "expr": "max by(probe_type, direction) (probe_duration_seconds{job=~\"blackbox_http|blackbox_icmp|blackbox_tcp\", probe_node=\"$node\", direction=~\"$direction\"})",
          "instant": true,
          "format": "table",
          "refId": "Max"
        },
        {
          "expr": "avg by(probe_type, direction) (avg_over_time(probe_duration_seconds{job=~\"blackbox_http|blackbox_icmp|blackbox_tcp\", probe_node=\"$node\", direction=~\"$direction\"}[5m]))",
          "instant": true,
          "format": "table",
          "refId": "Avg5m"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true },
            "indexByName": { "probe_type": 0, "direction": 1, "Value #Avg": 2, "Value #Max": 3, "Value #Avg5m": 4 },
            "renameByName": {
              "probe_type": "类型",
              "direction": "方向",
              "Value #Avg": "当前平均",
              "Value #Max": "当前最大",
              "Value #Avg5m": "5m 平均"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "当前平均|当前最大|5m 平均" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 1 },
                    { "color": "red", "value": 3 }
                  ]
                }
              },
              { "id": "max", "value": 5 }
            ]
          }
        ]
      }
    },
