    {
      "id": 105,
      "type": "row",
      "title": "🔐 SSL 证书状态",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 97 },
      "panels": []
    },
    {
      "id": 50,
      "type": "table",
      "title": "SSL 证书剩余有效期（HTTPS 探测目标）",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "排除了未启用 SSL（值为 0）的目标，避免误显示巨大的负数。",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 98 },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox_http\", probe_node=~\"$node\", direction=~\"$direction\"} - time()) / 86400  and  probe_ssl_earliest_cert_expiry{job=\"blackbox_http\"} > 0",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "network": true,
              "probe_type": true
            },
            "indexByName": {
              "probe_node": 0,
              "probe_region": 1,
              "direction": 2,
              "target": 3,
              "Value": 4
            },
            "renameByName": {
              "probe_node": "探测节点",
              "probe_region": "节点区域",
              "direction": "方向",
              "target": "目标",
              "Value": "剩余天数"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "剩余天数", "desc": false }]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "剩余天数" },
            "properties": [
              { "id": "unit", "value": "d" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": 7 },
                    { "color": "yellow", "value": 30 },
                    { "color": "green", "value": 60 }
                  ]
                }
              }
            ]
          }
        ]
      }
