      "id": 31,
      "type": "timeseries",
      "title": "容器内存使用 Top 10",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
