{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "多服务器统一监控面板 - 适配 Prometheus + Blackbox Exporter + node_exporter + cAdvisor + Tailscale 部署",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "multi-server-tailscale",
  "title": "多服务器监控总览 (Tailscale)",
  "tags": ["prometheus", "blackbox", "node_exporter", "cadvisor", "tailscale"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "6h", "1d"]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "skipUrlSync": false
      },
      {
        "name": "node",
        "type": "query",
        "label": "节点",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(up{job=\"node_exporter\"}, node)",
        "query": {
          "qryType": 1,
          "query": "label_values(up{job=\"node_exporter\"}, node)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "refresh": 2,
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "region",
        "type": "query",
        "label": "区域",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(up{job=\"node_exporter\", node=~\"$node\"}, region)",
        "query": {
          "qryType": 1,
          "query": "label_values(up{job=\"node_exporter\", node=~\"$node\"}, region)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "refresh": 2,
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "direction",
        "type": "query",
        "label": "探测方向",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(probe_success, direction)",
        "query": {
          "qryType": 1,
          "query": "label_values(probe_success, direction)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "refresh": 2,
        "sort": 1,
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "🌐 总体概览",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "在线服务器",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "count(up{job=\"node_exporter\", node=~\"$node\", region=~\"$region\"} == 1)",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "离线服务器",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "count(up{job=\"node_exporter\", node=~\"$node\", region=~\"$region\"} == 0) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "none"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "网络探测成功率",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "avg(probe_success{job=~\"blackbox_http|blackbox_icmp|blackbox_tcp\", probe_node=~\"$node\", direction=~\"$direction\"}) * 100",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "活跃 Docker 容器",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "count(rate(container_cpu_usage_seconds_total{node=~\"$node\", region=~\"$region\", name!=\"\"}[5m]) > 0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "none"
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "触发中告警",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none"
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Prometheus targets",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        { "expr": "count(up == 1)", "instant": true, "legendFormat": "在线", "refId": "A" },
        { "expr": "count(up == 0) or vector(0)", "instant": true, "legendFormat": "离线", "refId": "B" }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "在线" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "离线" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "🖥️ 服务器状态总览",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "id": 10,
      "type": "table",
      "title": "服务器一览（CPU / 内存 / 磁盘 / 运行时长 / 状态）",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "up{job=\"node_exporter\", node=~\"$node\", region=~\"$region\"}",
          "instant": true,
          "format": "table",
          "refId": "Up"
        },
        {
          "expr": "100 - (avg by(node, region, instance) (rate(node_cpu_seconds_total{mode=\"idle\", node=~\"$node\", region=~\"$region\"}[5m])) * 100)",
          "instant": true,
          "format": "table",
          "refId": "CPU"
        },
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{node=~\"$node\", region=~\"$region\"} / node_memory_MemTotal_bytes{node=~\"$node\", region=~\"$region\"}) * 100",
          "instant": true,
          "format": "table",
          "refId": "Mem"
        },
        {
          "expr": "max by(node, region, instance) ((1 - node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs|ramfs|nsfs|fuse.*\", node=~\"$node\", region=~\"$region\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs|ramfs|nsfs|fuse.*\", node=~\"$node\", region=~\"$region\"}) * 100)",
          "instant": true,
          "format": "table",
          "refId": "Disk"
        },
        {
          "expr": "(time() - node_boot_time_seconds{node=~\"$node\", region=~\"$region\"})",
          "instant": true,
          "format": "table",
          "refId": "Up time"
        },
        {
          "expr": "node_load1{node=~\"$node\", region=~\"$region\"}",
          "instant": true,
          "format": "table",
          "refId": "Load1"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "instance", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "Time 6": true,
              "__name__": true,
              "job": true,
              "network": true,
              "node 2": true,
              "node 3": true,
              "node 4": true,
              "node 5": true,
              "node 6": true,
              "region 2": true,
              "region 3": true,
              "region 4": true,
              "region 5": true,
              "region 6": true
            },
            "indexByName": {
              "node 1": 0,
              "region 1": 1,
              "instance": 2,
              "Value #Up": 3,
              "Value #CPU": 4,
              "Value #Mem": 5,
              "Value #Disk": 6,
              "Value #Load1": 7,
              "Value #Up time": 8
            },
            "renameByName": {
              "node 1": "节点",
              "region 1": "区域",
              "instance": "Tailscale 地址",
              "Value #Up": "状态",
              "Value #CPU": "CPU 使用率",
              "Value #Mem": "内存使用率",
              "Value #Disk": "磁盘使用率",
              "Value #Load1": "负载 (1m)",
              "Value #Up time": "运行时长"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "状态" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "🔴 离线", "color": "red", "index": 0 } } },
                  { "type": "value", "options": { "1": { "text": "🟢 在线", "color": "green", "index": 1 } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU 使用率" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 70 },
                    { "color": "red", "value": 85 }
                  ]
                }
              },
              { "id": "max", "value": 100 },
              { "id": "min", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "内存使用率" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 70 },
                    { "color": "red", "value": 85 }
                  ]
                }
              },
              { "id": "max", "value": 100 },
              { "id": "min", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "磁盘使用率" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 70 },
                    { "color": "red", "value": 85 }
                  ]
                }
              },
              { "id": "max", "value": 100 },
              { "id": "min", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "负载 (1m)" },
            "properties": [{ "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "运行时长" },
            "properties": [{ "id": "unit", "value": "s" }]
          }
        ]
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "📊 主机资源指标",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "panels": []
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "CPU 使用率（按节点）",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "100 - (avg by(node) (rate(node_cpu_seconds_total{mode=\"idle\", node=~\"$node\", region=~\"$region\"}[5m])) * 100)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "内存使用率（按节点）",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{node=~\"$node\", region=~\"$region\"} / node_memory_MemTotal_bytes{node=~\"$node\", region=~\"$region\"}) * 100",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "磁盘使用率（最大分区，按节点）",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "max by(node, mountpoint) ((1 - node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs|ramfs|nsfs|fuse.*\", node=~\"$node\", region=~\"$region\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs|ramfs|nsfs|fuse.*\", node=~\"$node\", region=~\"$region\"}) * 100)",
          "legendFormat": "{{node}} {{mountpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "系统负载 (1 分钟)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "node_load1{node=~\"$node\", region=~\"$region\"}",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "网络入流量（按节点）",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum by(node) (rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*|br-.*|tailscale.*\", node=~\"$node\", region=~\"$region\"}[5m]) * 8)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "网络出流量（按节点）",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "sum by(node) (rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*|br-.*|tailscale.*\", node=~\"$node\", region=~\"$region\"}[5m]) * 8)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "🐳 Docker 容器指标",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "panels": []
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "容器 CPU 使用率 Top 10",
