    {
      "id": 32,
      "type": "table",
      "title": "容器列表（按节点 + 运行时间）",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 49 },
      "targets": [
        {
          "expr": "time() - container_start_time_seconds{name!=\"\", node=~\"$node\", region=~\"$region\"}",
          "instant": true,
          "format": "table",
          "refId": "Uptime"
        },
        {
          "expr": "sum by(node, name) (rate(container_cpu_usage_seconds_total{name!=\"\", node=~\"$node\", region=~\"$region\"}[5m])) * 100",
          "instant": true,
          "format": "table",
          "refId": "CPU"
        },
        {
          "expr": "sum by(node, name) (container_memory_working_set_bytes{name!=\"\", node=~\"$node\", region=~\"$region\"})",
          "instant": true,
          "format": "table",
          "refId": "Mem"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "name", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "id": true,
              "image": true,
              "container_label_io_kubernetes_pod_name": true,
              "node 2": true,
              "node 3": true,
              "region 2": true,
              "region 3": true,
              "network": true,
              "role": true
            },
            "indexByName": {
              "node 1": 0,
              "region 1": 1,
              "name": 2,
              "Value #CPU": 3,
              "Value #Mem": 4,
              "Value #Uptime": 5
            },
            "renameByName": {
              "node 1": "节点",
              "region 1": "区域",
              "name": "容器名",
              "Value #CPU": "CPU 使用率",
              "Value #Mem": "内存占用",
              "Value #Uptime": "运行时长"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU 使用率" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "内存占用" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "运行时长" },
            "properties": [{ "id": "unit", "value": "s" }]
          }
        ]
      }
    },
    {
      "id": 104,
      "type": "row",
      "title": "🌍 网络探测（Blackbox）",
