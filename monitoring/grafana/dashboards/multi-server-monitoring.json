    {
      "id": 40,
      "type": "stat",
      "title": "HTTP 探测可用率",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 59 },
      "targets": [
        {
          "expr": "avg(probe_success{job=\"blackbox_http\", probe_node=~\"$node\", direction=~\"$direction\"}) * 100",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100
        }
      }
    },
