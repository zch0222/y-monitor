          "expr": "topk(10, sum by(node, name) (rate(container_cpu_usage_seconds_total{name!=\"\", node=~\"$node\", region=~\"$region\"}[5m])) * 100)",
          "legendFormat": "{{node}} / {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
