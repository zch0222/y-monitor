        {
          "expr": "topk(10, sum by(node, name) (container_memory_working_set_bytes{name!=\"\", node=~\"$node\", region=~\"$region\"}))",
          "legendFormat": "{{node}} / {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
