# Copy to .env and fill in your values.
# TS_IP can be generated automatically by setup.sh.

# Tailscale IPv4 of this machine (auto-filled by setup.sh)
TS_IP=100.x.x.x

# Timezone for all containers
TZ=Asia/Shanghai

# Logical environment label written to Loki
ENVIRONMENT=prod

# Node name label written to Loki
NODE_NAME=app-01

# Loki push endpoint. Can point to monitoring host or independent Loki host.
LOKI_PUSH_URL=http://100.x.x.x:3100/loki/api/v1/push
