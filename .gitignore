# Runtime data volumes (generated at runtime, do not commit)
monitoring/data/prometheus/*
!monitoring/data/prometheus/.gitkeep
monitoring/data/alertmanager/*
!monitoring/data/alertmanager/.gitkeep
monitoring/data/loki/*
!monitoring/data/loki/.gitkeep
monitoring/grafana/data/*
!monitoring/grafana/data/.gitkeep
monitor-agent/data/promtail/*
!monitor-agent/data/promtail/.gitkeep
loki/data/*
!loki/data/.gitkeep

# Generated Prometheus target files (generated by gen-targets.sh)
monitoring/prometheus/targets/*.yml

# .env files (contain passwords and machine-specific values)
monitor-agent/.env
monitoring/.env
loki/.env

# OS
.DS_Store
